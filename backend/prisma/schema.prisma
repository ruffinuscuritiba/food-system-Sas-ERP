generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  KITCHEN
  DELIVERY
  DEMO
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
}

enum CashMovementType {
  ENTRY
  EXIT
  SUPPLY
  WITHDRAW
}

enum StockMovementType {
  ENTRY
  EXIT
  LOSS
  INVENTORY
  ADJUSTMENT
  SALE
  PURCHASE
  PRODUCTION
  TRANSFER
  RETURN
  CANCELLATION
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
}

enum OrderType {
  DELIVERY
  DINE_IN
  PICKUP
}

enum OnlineOrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  COMPLETED
  CANCELED
}

enum OnlinePaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  EXPIRED
}

enum OnlinePaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
}

// ── Integrações (iFood, Rappi, etc.) ───────────────────────────────────────
enum IntegrationProvider {
  IFOOD
  RAPPI
  MOCK
}

// ── Impressoras ─────────────────────────────────────────────────────────────
enum PrinterConnectionType {
  BROWSER
  NETWORK
  USB
}

enum PrinterPaperWidth {
  MM_58
  MM_80
}

enum PrinterRole {
  KITCHEN
  BAR
  COUNTER
  DELIVERY
}

enum PrintJobStatus {
  PENDING
  SENT
  PRINTED
  FAILED
}

model Company {
  id String @id @default(cuid())

  name String

  description String?

  phone String?

  email String?

  plan String @default("DELIVERY")

  subscriptionStatus String @default("ACTIVE")

  dueDate DateTime?

  isBlocked Boolean @default(false)

  wasEverActive Boolean @default(false)

  users User[]

  modules CompanyModule[]

  products Product[]

  categories Category[]

  customers Customer[]

  orderItems OrderItem[]

  tableOrderItems TableOrderItem[]

  orders Order[]

  tableOrders TableOrder[]

  tables Table[]

  financials Financial[]

  ingredients Ingredient[]

  recipes Recipe[]

  stockMovements StockMovement[]

  companyTheme CompanyTheme?

  cashes Cash[]

  auditLogs AuditLog[]

  loyaltyAccounts LoyaltyAccount[]

  coupons Coupon[]

  payments Payment[]

  chatSessions ChatSession[]

  driverProfiles DriverProfile[]

  deliveryZones DeliveryZone[]

  importSessions ImportSession[]

  pizzaBorders PizzaBorder[]

  pizzaSizeConfigs PizzaSizeConfig[]

  complements Complement[]

  onlineOrders OnlineOrder[]

  whatsappConnections WhatsappConnection[]

  driverEarnings  DriverEarning[]
  driverPayments  DriverPayment[]

  integrationConfigs  IntegrationConfig[]
  integrationOrders   IntegrationOrder[]
  integrationEvents   IntegrationEventLog[]
  productCatalogMaps  ProductCatalogMap[]

  printers        Printer[]
  printerProfiles PrinterProfile[]
  printerJobs     PrinterJob[]

  metaPixelId       String?   // F9: Meta Pixel ID
  googleAnalyticsId String?   // F10: GA4 Measurement ID

  // ── Configurações centralizadas (Área de Configurações) ──────────────────
  whatsapp     String?
  cnpj         String?
  razaoSocial  String?

  // Endereço da loja
  zipCode      String?
  street       String?
  streetNumber String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?

  // Horários de funcionamento — JSON indexado por dia da semana (0=dom…6=sáb)
  // Estrutura: { "0": { "open": "11:00", "close": "22:00", "isOpen": false }, … }
  businessHours Json?

  // ── Configurações globais de entrega ──────────────────────────────────────
  // Método padrão: NEIGHBORHOOD | RADIUS | ROUTE
  deliveryMethod       String  @default("NEIGHBORHOOD")
  // Frete grátis quando pedido >= este valor (null = desativado)
  freeDeliveryAbove    Decimal? @db.Decimal(10, 2)
  // Entrega própria (entregadores da loja)
  ownDelivery          Boolean @default(true)
  // Raio máximo em km para entrega (null = sem limite)
  maxDeliveryRadius    Int?
  // Coordenadas da loja (usado para calcular raio e exibir no mapa)
  storeLat             Float?
  storeLng             Float?

  // ── Configurações de pedidos ──────────────────────────────────────────────
  acceptDelivery       Boolean @default(true)
  acceptPickup         Boolean @default(true)
  acceptDineIn         Boolean @default(true)
  estimatedPrepTime    Int     @default(30)   // minutos
  minimumOrderAmount   Decimal? @db.Decimal(10, 2)

  // ── Formas de pagamento na entrega ────────────────────────────────────────
  acceptCash           Boolean @default(true)
  acceptCreditCard     Boolean @default(true)
  acceptDebitCard      Boolean @default(true)
  acceptMealVoucher    Boolean @default(false)
  // JSON: [{id, name, isActive}]
  customPaymentMethods Json?

  // ── Configurações de impressão ────────────────────────────────────────────
  // JSON: {useAssistant, autoPrint, autoAccept, showCNPJ, showCategory, showDescription, pizzaItemFormat, addonGrouping}
  printingSettings     Json?

  // ── Segmento e layout ─────────────────────────────────────────────────────
  // Nicho do negócio — usado para seed automático na criação da conta
  businessSegment  String @default("RESTAURANTE")
  // Layout de produtos no PDV/Cardápio: LIST | GRID
  layoutType       String @default("LIST")
  // Raio dos botões: SM | MD | LG | FULL
  buttonRadius     String @default("MD")

  // ── Configurações financeiras / Split de Pagamentos ─────────────────────
  // Frequência do repasse automático: DAILY | WEEKLY
  repasseFrequency    String  @default("DAILY")
  // Horário do repasse (HH:MM, ex: "03:00")
  repasseTime         String  @default("03:00")
  // Dia da semana para repasse semanal (0=dom … 6=sáb)
  repasseWeekday      Int     @default(1)
  // Plano de liberação de vendas no crédito online: D0 | D30
  creditReleasePlan   String  @default("D30")
  // Dados da conta bancária ou chave PIX para recebimento
  // JSON: { type: "pix"|"bank", pixKey?: string, pixKeyType?: string,
  //         bank?: string, agency?: string, account?: string,
  //         accountType?: string, holderName?: string, document?: string }
  bankAccountData     Json?
  // Saldo em carteira (usado para abater mensalidade antes do repasse)
  walletBalance       Decimal @default(0) @db.Decimal(10, 2)

  // ── Construtor de Layout ────────────────────────────────────────────────────
  // JSON com configuração visual: { layoutType, buttonRadius, blocks[], ... }
  layoutConfig        Json?
  // Link de avaliação do Google (enviado ao cliente após entrega)
  googleReviewUrl     String?

  archivedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([name])
}

model User {
  id String @id @default(cuid())

  name String

  email String @unique

  password String

  role Role @default(ADMIN)

  isActive Boolean @default(true)

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  auditLogs AuditLog[]

  driverProfile DriverProfile?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([email])
}

model CompanyModule {
  id         String        @id @default(cuid())
  module     String
  active     Boolean       @default(false)
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  // Extended fields added by add_module_catalog migration
  moduleSlug String        @default("")
  status     ModuleStatus  @default(INACTIVE)
  trialEndsAt  DateTime?
  activatedAt  DateTime?
  updatedAt    DateTime     @default(now()) @updatedAt
  createdAt    DateTime     @default(now())

  @@index([companyId])
  @@index([moduleSlug])
}

model Category {
  id String @id @default(cuid())

  name String

  // pizza helper — permite selecionar múltiplos sabores nesta categoria
  allowMultipleFlavors Boolean @default(false)

  // "normal" | "bebidas" — controla layout e fluxo de cadastro especial
  categoryType String @default("normal")

  // colunas no grid (bebidas)
  displayColumns Int @default(4)

  // ordem de exibição (drag-and-drop)
  sortOrder Int @default(0)

  // White Label — banner exibido no topo do PDV ao selecionar esta categoria (Fase 5)
  bannerImage String?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  products Product[]

  complements Complement[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([companyId, sortOrder])

  @@index([name])
}

model Product {
  id String @id @default(cuid())

  name String

  description String?

  sku String?

  barcode String?

  unit String?

  deletedAt DateTime?

  size String?

  weight Float?

  imageUrl String?

  costPrice Decimal? @db.Decimal(10, 2)

  salePrice Decimal? @db.Decimal(10, 2)

  profitMargin Decimal? @db.Decimal(5, 2)

  isActive Boolean @default(true)

  trackStock Boolean @default(true)

  allowNegativeStock Boolean @default(false)

  // "standard" | "preparado" | "industrializado"
  productType String @default("standard")

  // EAN/código de barras para bebidas industrializadas
  eanCode String?

  // Vídeo demonstrativo do produto (URL)
  videoUrl String?
  hasVideo Boolean @default(false)

  // ordem de exibição (drag-and-drop)
  sortOrder Int @default(0)

  // futura área de destaque/promoção — não usado ainda
  isFeatured Boolean @default(false)

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  categoryId String?

  category Category? @relation(fields: [categoryId], references: [id])

  recipe Recipe?

  sizes ProductSize[]

  complements Complement[]

  orderItems OrderItem[]

  tableOrderItems TableOrderItem[]

  catalogMaps ProductCatalogMap[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([companyId, sortOrder])

  @@index([categoryId])

  @@index([name])
}

model ProductSize {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  price     Decimal  @db.Decimal(10, 2)
  companyId String
  createdAt DateTime @default(now())

  @@unique([productId, size])
  @@index([productId])
  @@index([companyId])
}

model Customer {
  id String @id @default(cuid())

  name String

  phone String

  email String?

  address String?

  notes String?

  orders Order[]

  loyaltyAccount LoyaltyAccount?

  coupons Coupon[]

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([phone])
}

model Order {
  id String @id @default(cuid())

  // Número sequencial por tenant — exibição humana (Ex: Pedido #42)
  number Int @default(0)

  customerId String?

  customer Customer? @relation(fields: [customerId], references: [id])

  // Tipo de atendimento usando enum tipado (antes era String)
  orderType OrderType @default(DINE_IN)

  // Dados do cliente (snapshot no momento do pedido — imutável para histórico/BI)
  customerName    String?
  customerPhone   String?
  deliveryAddress String?
  neighborhood    String?

  status OrderStatus @default(PENDING)

  paymentMethod PaymentMethod

  subtotal Decimal @db.Decimal(10, 2)

  deliveryFee Decimal @default(0) @db.Decimal(10, 2)

  driverFee Decimal? @db.Decimal(10, 2)

  driverId String?

  driver DriverProfile? @relation(fields: [driverId], references: [id])

  deliveryZoneId String?

  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])

  assignedAt DateTime?

  pickedUpAt DateTime?

  total Decimal @db.Decimal(10, 2)

  notes String?

  items OrderItem[]

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  startedAt DateTime?

  finishedAt DateTime?

  completedAt DateTime?

  confirmedAt DateTime?

  preparingAt DateTime?

  readyAt DateTime?

  outForDeliveryAt DateTime?

  deliveredAt DateTime?

  cancelledAt DateTime?

  payment Payment?

  driverEarning DriverEarning?

  tableId String?

  table Table? @relation(fields: [tableId], references: [id])

  // Canal de origem do pedido (PDV, ONLINE, WHATSAPP, IFOOD, RAPPI, MOCK)
  channel         String  @default("PDV")

  // ID externo para idempotência em integrações (ex: orderId do iFood)
  externalOrderId String? @unique

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([status])
  @@index([createdAt])
  @@index([driverId])
  @@index([orderType])
  @@index([deliveryZoneId])
  @@index([tableId])
  @@index([channel])
}

model DriverProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  phone        String?
  vehicleType  String?
  vehiclePlate String?
  isAvailable  Boolean  @default(true)
  currentLat   Float?
  currentLng   Float?
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  orders       Order[]
  earnings     DriverEarning[]
  payments     DriverPayment[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

model DeliveryZone {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  // NEIGHBORHOOD | RADIUS | ROUTE
  type         String   @default("NEIGHBORHOOD")
  neighborhood String?
  baseFee      Decimal? @db.Decimal(10, 2)
  pricePerKm   Decimal? @db.Decimal(10, 2)
  clientFee    Decimal  @db.Decimal(10, 2)
  driverShare  Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  // Campos para tipo RADIUS — raio em km e centro do círculo
  radiusKm     Decimal? @db.Decimal(5, 2)
  lat          Float?
  lng          Float?
  // Cor visual no mapa (hex)
  color        String   @default("#f97316")
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String

  order Order @relation(fields: [orderId], references: [id])

  productId String

  product Product @relation(fields: [productId], references: [id])

  productName String

  productSku String?

  quantity Decimal @db.Decimal(10, 2)

  unitPrice Decimal @db.Decimal(10, 2)

  subtotal Decimal @db.Decimal(10, 2)

  productCost Decimal? @db.Decimal(10,2)

  cmv Decimal? @db.Decimal(10,2)

  profit Decimal? @db.Decimal(10,2)

  notes String?

  // snapshot dos complementos selecionados (JSON)
  complementsData Json?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  selectedComplements OrderItemComplement[]

  createdAt DateTime @default(now())

  @@index([companyId])

  @@index([orderId])

  @@index([productId])
}

model Table {
  id String @id @default(cuid())

  number Int

  status TableStatus @default(FREE)

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  orders       TableOrder[]

  dineInOrders Order[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model TableOrder {
  id String @id @default(cuid())

  tableId String

  table Table @relation(fields: [tableId], references: [id])

  status OrderStatus @default(PENDING)

  total Decimal @db.Decimal(10, 2)

  items TableOrderItem[]

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model TableOrderItem {
  id String @id @default(cuid())

  tableOrderId String

  tableOrder TableOrder @relation(fields: [tableOrderId], references: [id])

  productId String

  product Product @relation(fields: [productId], references: [id])

  quantity Decimal @db.Decimal(10, 2)

  unitPrice Decimal @db.Decimal(10, 2)

  subtotal Decimal @db.Decimal(10, 2)

  notes String?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Financial {
  id String @id @default(cuid())

  type FinancialType

  category String

  description String?

  amount Decimal @db.Decimal(10, 2)

  paymentMethod PaymentMethod?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([type])
}

model Ingredient {
  id String @id @default(cuid())

  name String

  sku String?

  barcode String?

  stock Decimal @db.Decimal(10, 2)

  minimumStock Decimal @default(0) @db.Decimal(10, 2)

  unit String

  cost Decimal @db.Decimal(10, 2)

  averageCost Decimal @default(0) @db.Decimal(10, 2)

  lastPurchaseCost Decimal @default(0) @db.Decimal(10, 2)

  allowNegativeStock Boolean @default(false)

  isActive Boolean @default(true)

  deletedAt DateTime?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  stockMovements StockMovement[]

  recipeItems RecipeItem[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([deletedAt])

  @@index([name])
}

model Recipe {
  id String @id @default(cuid())

  productId String @unique

  product Product @relation(fields: [productId], references: [id])

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  items RecipeItem[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model RecipeItem {
  id String @id @default(cuid())

  recipeId String

  ingredientId String

  quantity Decimal @db.Decimal(10, 2)

  recipe Recipe @relation(fields: [recipeId], references: [id])

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  createdAt DateTime @default(now())

  @@index([recipeId])

  @@index([ingredientId])
}

model StockMovement {
  id String @id @default(cuid())

  ingredientId String

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  type StockMovementType

  quantity Decimal @db.Decimal(10, 2)

  previousStock Decimal @db.Decimal(10, 2)

  currentStock Decimal @db.Decimal(10, 2)

  unitCost Decimal? @db.Decimal(10, 2)

  totalCost Decimal? @db.Decimal(10, 2)

  reason String?

  referenceId String?

  referenceType String?

  performedById String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([companyId])

  @@index([ingredientId])

  @@index([type])

  @@index([createdAt])
}

model CompanyTheme {
  id String @id @default(cuid())

  companyId String @unique

  company Company @relation(fields: [companyId], references: [id])

  primaryColor String @default("#ef4444")

  secondaryColor String @default("#0f172a")

  // White Label — cor de destaque (CTAs secundários, badges)
  accentColor String @default("#f97316")

  backgroundColor String @default("#020617")

  textColor String @default("#ffffff")

  logoUrl String?

  bannerUrl String?

  // White Label — favicon próprio
  faviconUrl String?

  // White Label — fonte do sistema (Google Fonts name)
  fontFamily String @default("Inter")

  // White Label — raio de cantos (px) — afeta cards, botões, modais
  borderRadius Int @default(16)

  // White Label — variante visual do PDV: "dark" (atual) | "light" | "neutral"
  pdvStyle String @default("dark")

  pizzaPricingMode String @default("MAX")

  darkMode Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Cash {
  id String @id @default(cuid())

  openingValue Decimal @db.Decimal(10, 2)

  balance Decimal @db.Decimal(10, 2)

  entries Decimal @default(0) @db.Decimal(10, 2)

  exits Decimal @default(0) @db.Decimal(10, 2)

  isOpen Boolean @default(true)

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model AuditLog {
  id String @id @default(cuid())

  action String

  entity String

  entityId String?

  description String?

  metadata Json?

  ipAddress String?

  userAgent String?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  userId String?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])

  @@index([userId])

  @@index([entity])

  @@index([action])

  @@index([createdAt])
}

// ─── F8: Gateway de Pagamento ───────────────────────────────

model Payment {
  id          String        @id @default(uuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  externalId  String?       // ID gerado pelo Mercado Pago / PagSeguro
  provider    PaymentProvider
  status      PaymentStatus @default(PENDING)
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("BRL")
  checkoutUrl String?       // URL de redirect para o cliente
  webhookData Json?         // payload bruto do webhook
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([orderId])
  @@index([externalId])
  @@index([companyId])
}

enum PaymentProvider {
  MERCADO_PAGO
  PAGSEGURO
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
}

// ─── F7: Sistema de Fidelidade ──────────────────────────────

model LoyaltyAccount {
  id           String             @id @default(uuid())
  customerId   String             @unique
  customer     Customer           @relation(fields: [customerId], references: [id])
  companyId    String
  company      Company            @relation(fields: [companyId], references: [id])
  totalPoints  Int                @default(0)
  totalCashback Decimal           @default(0) @db.Decimal(10, 2)
  transactions PointTransaction[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([customerId, companyId])
  @@index([companyId])
}

model PointTransaction {
  id               String          @id @default(uuid())
  loyaltyAccountId String
  loyaltyAccount   LoyaltyAccount  @relation(fields: [loyaltyAccountId], references: [id])
  orderId          String?
  points           Int             // positivo = ganho, negativo = resgatado
  type             PointType
  description      String?
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())

  @@index([loyaltyAccountId])
}

enum PointType {
  EARNED
  REDEEMED
  EXPIRED
  BONUS
  CASHBACK
}

model Coupon {
  id              String       @id @default(uuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  code            String       @unique
  type            CouponType
  value           Decimal      @db.Decimal(10, 2) // % ou R$ dependendo do type
  minOrderAmount  Decimal?     @db.Decimal(10, 2)
  maxDiscount     Decimal?     @db.Decimal(10, 2)
  usageLimit      Int?
  usageCount      Int          @default(0)
  customerId      String?
  customer        Customer?    @relation(fields: [customerId], references: [id])
  pointsCost      Int?         // pontos necessários para resgatar
  active          Boolean      @default(true)
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([companyId])
  @@index([code])
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

// ─── F6: Chatbot IA ─────────────────────────────────────────

model ChatSession {
  id         String        @id @default(uuid())
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  customerId String?
  sessionKey String        @unique @default(uuid()) // usado no frontend (cookie)
  messages   ChatMessage[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([companyId])
  @@index([sessionKey])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  role      ChatRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

enum ChatRole {
  USER
  ASSISTANT
}

// ─── BI / AI / Alertas ──────────────────────────────────────

enum AlertType {
  LOW_STOCK
  HIGH_CMV
  REVENUE_DROP
  TICKET_DROP
  CANCELLATION_SPIKE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model KpiSnapshot {
  id              String   @id @default(cuid())
  companyId       String
  snapshotAt      DateTime
  revenue         Decimal  @db.Decimal(14, 2)
  cmv             Decimal  @db.Decimal(14, 2)
  grossProfit     Decimal  @db.Decimal(14, 2)
  grossMargin     Decimal  @db.Decimal(7, 4)
  orderCount      Int
  avgTicket       Decimal  @db.Decimal(10, 2)
  cancelledCount  Int
  deliveryCount   Int
  dineInCount     Int
  pickupCount     Int
  pixRevenue      Decimal  @db.Decimal(14, 2)
  cardRevenue     Decimal  @db.Decimal(14, 2)
  cashRevenue     Decimal  @db.Decimal(14, 2)
  createdAt       DateTime @default(now())

  @@unique([companyId, snapshotAt])
  @@index([companyId])
  @@index([snapshotAt])
}

model Alert {
  id          String        @id @default(cuid())
  companyId   String
  type        AlertType
  severity    AlertSeverity
  title       String
  message     String        @db.Text
  metadata    Json?
  read        Boolean       @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([companyId])
  @@index([read])
  @@index([createdAt])
}

model AiConversation {
  id          String      @id @default(cuid())
  companyId   String
  userId      String?
  title       String?
  messages    AiMessage[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([companyId])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           ChatRole
  content        String         @db.Text
  tokensUsed     Int?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

model OperationalCost {
  id          String   @id @default(cuid())
  companyId   String
  category    String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  recurring   Boolean  @default(false)
  period      String?  // MONTHLY | WEEKLY | DAILY
  referenceAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([referenceAt])
}

// ── Module Catalog ─────────────────────────────────────────────────────────

enum ModuleCategory {
  OPERACAO
  MARKETING
  FINANCEIRO
  AUTOMACAO
}

enum ModuleStatus {
  TRIAL
  ACTIVE
  INACTIVE
  EXPIRED
}

model Module {
  id              String         @id
  slug            String         @unique
  name            String
  description     String
  longDescription String?
  icon            String
  category        ModuleCategory
  price           Decimal?       @db.Decimal(10, 2)
  isFree          Boolean        @default(false)
  badge           String?
  badgeColor      String?
  benefits        String[]
  isHighlighted   Boolean        @default(false)
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())

  @@index([category])
  @@index([slug])
}

// ── Preços dos planos (gerenciável pelo Super Admin) ───────────────────────────
model PlanConfig {
  plan      String   @id       // "BASIC" | "PRO" | "ENTERPRISE"
  price     Decimal  @db.Decimal(10, 2)
  label     String
  tagline   String?
  updatedAt DateTime @updatedAt
}

// ── Impressoras ─────────────────────────────────────────────────────────────

model Printer {
  id             String                @id @default(cuid())
  companyId      String
  company        Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  brand          String?
  connectionType PrinterConnectionType @default(BROWSER)
  address        String?               // IP:port para NETWORK, caminho de dispositivo para USB
  paperWidth     PrinterPaperWidth     @default(MM_80)
  isOnline       Boolean               @default(false)
  isActive       Boolean               @default(true)
  lastSeenAt     DateTime?
  profiles       PrinterProfile[]
  jobs           PrinterJob[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([companyId])
}

model PrinterProfile {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  printerId String
  printer   Printer     @relation(fields: [printerId], references: [id], onDelete: Cascade)
  role      PrinterRole
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  @@unique([printerId, role])
  @@index([companyId])
}

model PrinterJob {
  id         String         @id @default(cuid())
  companyId  String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  printerId  String
  printer    Printer        @relation(fields: [printerId], references: [id], onDelete: Cascade)
  orderId    String?
  template   String         // "KITCHEN" | "BAR" | "CASHIER" | "DELIVERY"
  payload    Json
  status     PrintJobStatus @default(PENDING)
  attempts   Int            @default(0)
  printedAt  DateTime?
  failReason String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([companyId, status])
  @@index([printerId, status])
  @@index([orderId])
}

// ─── Smart Import (cadastro inteligente por imagem/PDF/XML) ─────────────────
enum ImportType {
  MENU
  INVOICE
}

enum ImportStatus {
  PROCESSING
  DONE
  ERROR
}

model ImportSession {
  id        String       @id @default(cuid())
  companyId String
  company   Company      @relation(fields: [companyId], references: [id])
  type      ImportType
  status    ImportStatus @default(PROCESSING)
  fileUrl   String?
  rawResult Json?
  errorMsg  String?
  items     ImportItem[]
  logs      ImportLog[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([companyId])
  @@index([status])
}

model ImportItem {
  id         String        @id @default(cuid())
  sessionId  String
  session    ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  data       Json
  confidence Float?
  confirmed  Boolean       @default(false)
  savedId    String?
  createdAt  DateTime      @default(now())

  @@index([sessionId])
}

model ImportLog {
  id        String        @id @default(cuid())
  sessionId String
  session   ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  level     String
  message   String
  createdAt DateTime      @default(now())

  @@index([sessionId])
}

// ── Pizza Borders ─────────────────────────────────────────────────────────────
// PizzaSize enum removido — todas as colunas foram convertidas para TEXT no banco
// via migrations 20260526010000 e 20260527300000. String é o tipo correto.

model PizzaBorder {
  id        String            @id @default(cuid())
  companyId String
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  sizes     PizzaBorderSize[]

  @@index([companyId])
}

model PizzaBorderSize {
  id           String      @id @default(cuid())
  pizzaBorderId String
  pizzaBorder  PizzaBorder @relation(fields: [pizzaBorderId], references: [id], onDelete: Cascade)
  size         String
  price        Decimal     @db.Decimal(10, 2)

  @@unique([pizzaBorderId, size])
  @@index([pizzaBorderId])
}

// ── Configuração de tamanhos de pizza por empresa ───────────────────────────────
// Cada empresa pode definir: quantos sabores são permitidos por tamanho e quantas fatias tem

model PizzaSizeConfig {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // size: usa String (não enum) — migration 20260530170000 converteu enum→text
  // para resolver erro Postgres 42883 (text = PizzaSize) no upsert.
  size       String
  label      String    // "Pequena", "Média", "Grande", "Família", "Extra Grande"
  slices     Int       @default(8)
  maxFlavors Int       @default(1)
  isActive   Boolean   @default(true)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([companyId, size])
  @@index([companyId])
}

// ── Sistema de Complementos (estilo iFood) ──────────────────────────────────────

enum ComplementType {
  INGREDIENTES
  ESPECIFICACOES
  CROSS_SELL
  DESCARTAVEIS
}

model Complement {
  id             String           @id @default(cuid())
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name           String
  type           ComplementType   @default(INGREDIENTES)
  required       Boolean          @default(false)
  chargesExtra   Boolean          @default(true)
  multipleChoice Boolean          @default(false)
  minOptions     Int              @default(0)
  maxOptions     Int              @default(1)
  sortOrder      Int              @default(0)
  isActive       Boolean          @default(true)
  options        ComplementOption[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([companyId])
  @@index([productId])
  @@index([categoryId])
}

model ComplementOption {
  id                   String               @id @default(cuid())
  complementId         String
  complement           Complement           @relation(fields: [complementId], references: [id], onDelete: Cascade)
  name                 String
  price                Decimal              @default(0) @db.Decimal(10, 2)
  imageUrl             String?
  isActive             Boolean              @default(true)
  sortOrder            Int                  @default(0)
  orderItemComplements OrderItemComplement[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([complementId])
}

model OrderItemComplement {
  id                 String           @id @default(cuid())
  orderItemId        String
  orderItem          OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  complementOptionId String
  complementOption   ComplementOption @relation(fields: [complementOptionId], references: [id])
  complementName     String           // snapshot
  optionName         String           // snapshot
  price              Decimal          @db.Decimal(10, 2) // snapshot
  quantity           Int              @default(1)
  createdAt          DateTime         @default(now())

  @@index([orderItemId])
  @@index([complementOptionId])
}

// ─── Online Orders (cardápio digital / delivery público) ─────────────────────

model OnlineOrder {
  id                      String   @id @default(cuid())
  companyId               String
  company                 Company  @relation(fields: [companyId], references: [id])
  customerName            String
  customerPhone           String
  customerEmail           String?
  orderType               OrderType @default(DELIVERY)
  address                 String?
  addressNumber           String?
  neighborhood            String?
  city                    String?
  state                   String?
  zipcode                 String?
  complement              String?
  items                   Json
  subtotal                Decimal  @db.Decimal(10, 2)
  deliveryFee             Decimal  @default(0) @db.Decimal(10, 2)
  discount                Decimal  @default(0) @db.Decimal(10, 2)
  total                   Decimal  @db.Decimal(10, 2)
  paymentMethod           OnlinePaymentMethod @default(PIX)
  paymentGateway          String   @default("MERCADOPAGO")
  paymentStatus           OnlinePaymentStatus @default(PENDING)
  orderStatus             OnlineOrderStatus   @default(PENDING)
  mercadopagoPaymentId    String?
  mercadopagoPreferenceId String?
  pixQrcode               String?
  pixCopyPaste            String?
  pixExpiresAt            DateTime?
  notes                   String?
  paidAt                  DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([companyId])
  @@index([paymentStatus])
  @@index([orderStatus])
  @@index([createdAt])
}

model PaymentWebhook {
  id        String   @id @default(cuid())
  companyId String?
  gateway   String
  eventId   String
  event     String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([gateway, eventId])
  @@index([processed])
  @@index([companyId])
}

// ─── WhatsApp IA ──────────────────────────────────────────────────────────────

model WhatsappConnection {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String   // "WhatsApp Principal"
  provider     String   @default("EVOLUTION") // EVOLUTION | CLOUD_API | ZAPI | TWILIO
  instanceName String?
  apiUrl       String?
  apiToken     String?  @db.Text
  phoneNumberId String? // Cloud API phone_number_id
  webhookToken String?  // token para verificar webhooks recebidos
  phoneNumber  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings      WhatsappAiSettings?
  conversations WhatsappConversation[]

  @@index([companyId])
}

model WhatsappAiSettings {
  id               String   @id @default(cuid())
  connectionId     String   @unique
  connection       WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  companyId        String
  aiProvider       String   @default("GEMINI")      // GEMINI | ANTHROPIC | OPENAI
  aiModel          String   @default("gemini-1.5-flash")
  attendantName    String   @default("Atendente")
  systemPrompt     String?  @db.Text
  greetingMessage  String?  @db.Text
  offlineMessage   String?  @db.Text
  transferKeywords String?                           // vírgula separado
  mode             String   @default("AUTO")         // AUTO | HYBRID | MANUAL
  typingDelay      Int      @default(1500)           // ms delay fake digitando
  messageDelay     Int      @default(800)            // ms entre mensagens
  useEmojis        Boolean  @default(true)
  businessHoursStart String @default("08:00")
  businessHoursEnd   String @default("22:00")
  businessDays     String   @default("1,2,3,4,5,6") // 0=dom..6=sab
  isActive         Boolean  @default(true)

  // ── Personalidade avançada (ref. concorrente) ─────────────────────────────
  responseStyle       String  @default("DIRECT")      // DIRECT | CONVERSATIONAL
  personalityType     String  @default("FRIENDLY")    // FRIENDLY | PLAYFUL | FORMAL
  emojiUsage          String  @default("MODERATE")    // NONE | MODERATE | ALWAYS
  advancedPersonality Boolean @default(false)
  speechHabits        String? @db.Text                // vícios de linguagem
  characteristics     String? @db.Text                // características
  principles          String? @db.Text                // princípios
  humor               String? @db.Text                // humor / tom

  // ── Comportamento de pedidos ──────────────────────────────────────────────
  menuLinkStyle          String  @default("BUTTON")    // BUTTON | TEXT
  conversationalOrdering Boolean @default(false)       // anotar pedido na conversa
  // LINK_ONLY | LINK_THEN_HUMAN_3 | LINK_THEN_HUMAN_2 | ALWAYS_HUMAN
  orderHandlingMode      String  @default("LINK_ONLY")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
}

model WhatsappConversation {
  id            String   @id @default(cuid())
  connectionId  String
  connection    WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  companyId     String
  customerPhone String
  customerName  String?
  status        String   @default("ACTIVE")   // ACTIVE | CLOSED | TRANSFERRED
  mode          String   @default("AI")        // AI | HUMAN | PAUSED
  context       Json?                          // { cart, step, address, phone, ... }
  orderId       String?
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages WhatsappMessage[]

  @@unique([connectionId, customerPhone])
  @@index([companyId])
  @@index([connectionId])
}

model WhatsappMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  companyId      String
  role           String   // USER | ASSISTANT | SYSTEM
  content        String   @db.Text
  externalId     String?
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([companyId])
}

// ── Leads capturados pela Kely (IA Demo pública) ──────────────────────────────

model Lead {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  sessionToken        String   @unique
  name                String?
  company             String?
  whatsapp            String?
  recommendedPlan     String?
  source              String   @default("IA_DEMO")
  conversationSummary String?
  status              String   @default("NOVO")
  waClickedAt         DateTime?

  @@index([status])
  @@index([createdAt])
}

// ── Driver Earnings & Payments ─────────────────────────────────────────────

enum DriverPaymentStatus {
  PENDING
  PAID
}

model DriverEarning {
  id              String              @id @default(cuid())
  orderId         String              @unique
  order           Order               @relation(fields: [orderId], references: [id])
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  driverProfileId String
  driverProfile   DriverProfile       @relation(fields: [driverProfileId], references: [id])
  customerFee     Decimal             @db.Decimal(10, 2)
  driverAmount    Decimal             @db.Decimal(10, 2)
  platformFee     Decimal             @db.Decimal(10, 2)
  status          DriverPaymentStatus @default(PENDING)
  driverPaymentId String?
  driverPayment   DriverPayment?      @relation(fields: [driverPaymentId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([companyId])
  @@index([driverProfileId])
  @@index([driverPaymentId])
}

model DriverPayment {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  driverProfileId String
  driverProfile   DriverProfile       @relation(fields: [driverProfileId], references: [id])
  earnings        DriverEarning[]
  totalAmount     Decimal             @db.Decimal(10, 2)
  status          DriverPaymentStatus @default(PENDING)
  paidAt          DateTime?
  financialId     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([companyId])
  @@index([driverProfileId])
}

// ═══════════════════════════════════════════════════════════════════════════
// INTEGRAÇÕES — iFood, Rappi e futuros marketplaces
// Arquitetura Provider Pattern: novos provedores = novo provider file, sem
// tocar nos models abaixo.
// ═══════════════════════════════════════════════════════════════════════════

model IntegrationConfig {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  provider        IntegrationProvider
  isActive        Boolean             @default(false)
  sandboxMode     Boolean             @default(true)
  clientId        String?
  apiKeyEncrypted String?   // clientSecret do iFood (OAuth2)
  merchantId      String?
  webhookSecret   String?
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  orders          IntegrationOrder[]

  @@unique([companyId, provider])
  @@index([companyId])
  @@index([provider])
}

model IntegrationOrder {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  configId        String
  config          IntegrationConfig   @relation(fields: [configId], references: [id])
  orderId         String?             // FK para Order interno — null enquanto processando
  externalOrderId String              @unique
  provider        IntegrationProvider
  externalStatus  String?
  ackSentAt       DateTime?
  errorMessage    String?
  rawPayload      Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([companyId])
  @@index([orderId])
}

model IntegrationEventLog {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  provider        IntegrationProvider
  eventType       String
  externalOrderId String?
  processedAt     DateTime?
  status          String              @default("RECEIVED")
  errorMessage    String?
  rawPayload      Json?
  createdAt       DateTime            @default(now())

  @@index([companyId])
  @@index([externalOrderId])
  @@index([createdAt])
}

model ProductCatalogMap {
  id                String              @id @default(cuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id])
  provider          IntegrationProvider
  externalProductId String
  internalProductId String
  product           Product             @relation(fields: [internalProductId], references: [id])
  externalVariantId String?
  sizeMapping       Json?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([companyId, provider, externalProductId])
  @@index([companyId])
  @@index([internalProductId])
}

// ── Layout Template ──────────────────────────────────────────────────────────
// Templates de layout que o Super Admin cria para aplicar às lojas.
// Defaults são hardcoded no frontend; este model armazena templates customizados.
model LayoutTemplate {
  id        String   @id @default(cuid())
  name      String
  segment   String   @default("CUSTOM")
  // JSON: { layoutType, buttonRadius, blocks: [{ id, label, visible, order }] }
  config    Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
