{
  "name": "foodsaas-printer-agent",
  "version": "1.0.0",
  "description": "FoodSaaS Printer Agent — ESC/POS polling agent for thermal printers",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "pm2": "pm2 start index.js --name printer-agent --restart-delay=3000",
    "build": "pkg . --compress GZip",
    "build:win": "pkg . --targets node18-win-x64 --output dist/FoodSaaS-Printer-Agent-win.exe --compress GZip",
    "build:linux": "pkg . --targets node18-linux-x64 --output dist/FoodSaaS-Printer-Agent-linux --compress GZip",
    "build:all": "pkg . --targets node18-win-x64,node18-linux-x64 --out-path dist --compress GZip"
  },
  "dependencies": {
    "escpos": "^3.0.0-alpha.6"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": "index.js",
    "assets": [],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist"
  },
  "engines": {
    "node": ">=18"
  }
}
