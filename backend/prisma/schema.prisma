generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  KITCHEN
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
}

enum CashMovementType {
  ENTRY
  EXIT
  SUPPLY
  WITHDRAW
}

enum StockMovementType {
  ENTRY
  EXIT
  LOSS
  INVENTORY
  ADJUSTMENT
  SALE
  PURCHASE
  PRODUCTION
  TRANSFER
  RETURN
  CANCELLATION
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
}

enum OrderType {
  DELIVERY
  DINE_IN
  PICKUP
}

model Company {
  id String @id @default(cuid())

  name String

  description String?

  phone String?

  email String?

  plan String @default("DELIVERY")

  subscriptionStatus String @default("ACTIVE")

  dueDate DateTime?

  isBlocked Boolean @default(false)

  users User[]

  modules CompanyModule[]

  products Product[]

  categories Category[]

  customers Customer[]

  orderItems OrderItem[]

  tableOrderItems TableOrderItem[]

  orders Order[]

  tableOrders TableOrder[]

  tables Table[]

  financials Financial[]

  ingredients Ingredient[]

  recipes Recipe[]

  stockMovements StockMovement[]

  companyTheme CompanyTheme?

  cashes Cash[]

  auditLogs AuditLog[]

  loyaltyAccounts LoyaltyAccount[]

  coupons Coupon[]

  payments Payment[]

  chatSessions ChatSession[]

  driverProfiles DriverProfile[]

  deliveryZones DeliveryZone[]

  metaPixelId       String?   // F9: Meta Pixel ID
  googleAnalyticsId String?   // F10: GA4 Measurement ID

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([name])
}

model User {
  id String @id @default(cuid())

  name String

  email String @unique

  password String

  role Role @default(ADMIN)

  isActive Boolean @default(true)

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  auditLogs AuditLog[]

  driverProfile DriverProfile?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([email])
}

model CompanyModule {
  id String @id @default(cuid())

  module String

  active Boolean @default(false)

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Category {
  id String @id @default(cuid())

  name String

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  products Product[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([name])
}

model Product {
  id String @id @default(cuid())

  name String

  description String?

  sku String?

  barcode String?

  unit String?

  deletedAt DateTime?

  size String?

  weight Float?

  imageUrl String?

  costPrice Decimal? @db.Decimal(10, 2)

  salePrice Decimal? @db.Decimal(10, 2)

  profitMargin Decimal? @db.Decimal(5, 2)

  isActive Boolean @default(true)

  trackStock Boolean @default(true)

  allowNegativeStock Boolean @default(false)

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  categoryId String?

  category Category? @relation(fields: [categoryId], references: [id])

  recipe Recipe?

  sizes ProductSize[]

  orderItems OrderItem[]

  tableOrderItems TableOrderItem[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([categoryId])

  @@index([name])
}

model ProductSize {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  price     Decimal  @db.Decimal(10, 2)
  companyId String
  createdAt DateTime @default(now())

  @@unique([productId, size])
  @@index([productId])
  @@index([companyId])
}

model Customer {
  id String @id @default(cuid())

  name String

  phone String

  email String?

  address String?

  notes String?

  orders Order[]

  loyaltyAccount LoyaltyAccount?

  coupons Coupon[]

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([phone])
}

model Order {
  id String @id @default(cuid())

  customerId String?

  customer Customer? @relation(fields: [customerId], references: [id])

  status OrderStatus @default(PENDING)

  paymentMethod PaymentMethod

  subtotal Decimal @db.Decimal(10, 2)

  deliveryFee Decimal @default(0) @db.Decimal(10, 2)

  driverFee Decimal? @db.Decimal(10, 2)

  driverId String?

  driver DriverProfile? @relation(fields: [driverId], references: [id])

  assignedAt DateTime?

  pickedUpAt DateTime?

  total Decimal @db.Decimal(10, 2)

  notes String?

  items OrderItem[]

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  startedAt DateTime?

  finishedAt DateTime?

  completedAt DateTime?

  confirmedAt DateTime?

  preparingAt DateTime?

  readyAt DateTime?

  outForDeliveryAt DateTime?

  deliveredAt DateTime?

  cancelledAt DateTime?

  payment Payment?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([status])

  @@index([createdAt])

  @@index([driverId])
}

model DriverProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  phone        String?
  vehicleType  String?
  vehiclePlate String?
  isAvailable  Boolean  @default(true)
  currentLat   Float?
  currentLng   Float?
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

model DeliveryZone {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  type         String   @default("NEIGHBORHOOD")
  neighborhood String?
  baseFee      Decimal? @db.Decimal(10, 2)
  pricePerKm   Decimal? @db.Decimal(10, 2)
  clientFee    Decimal  @db.Decimal(10, 2)
  driverShare  Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String

  order Order @relation(fields: [orderId], references: [id])

  productId String

  product Product @relation(fields: [productId], references: [id])

  productName String

  productSku String?

  quantity Decimal @db.Decimal(10, 2)

  unitPrice Decimal @db.Decimal(10, 2)

  subtotal Decimal @db.Decimal(10, 2)

  productCost Decimal? @db.Decimal(10,2)

  cmv Decimal? @db.Decimal(10,2)

  profit Decimal? @db.Decimal(10,2)

  notes String?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])

  @@index([orderId])

  @@index([productId])
}

model Table {
  id String @id @default(cuid())

  number Int

  status TableStatus @default(FREE)

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  orders TableOrder[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model TableOrder {
  id String @id @default(cuid())

  tableId String

  table Table @relation(fields: [tableId], references: [id])

  status OrderStatus @default(PENDING)

  total Decimal @db.Decimal(10, 2)

  items TableOrderItem[]

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model TableOrderItem {
  id String @id @default(cuid())

  tableOrderId String

  tableOrder TableOrder @relation(fields: [tableOrderId], references: [id])

  productId String

  product Product @relation(fields: [productId], references: [id])

  quantity Decimal @db.Decimal(10, 2)

  unitPrice Decimal @db.Decimal(10, 2)

  subtotal Decimal @db.Decimal(10, 2)

  notes String?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Financial {
  id String @id @default(cuid())

  type FinancialType

  category String

  description String?

  amount Decimal @db.Decimal(10, 2)

  paymentMethod PaymentMethod?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([type])
}

model Ingredient {
  id String @id @default(cuid())

  name String

  sku String?

  barcode String?

  stock Decimal @db.Decimal(10, 2)

  minimumStock Decimal @default(0) @db.Decimal(10, 2)

  unit String

  cost Decimal @db.Decimal(10, 2)

  averageCost Decimal @default(0) @db.Decimal(10, 2)

  lastPurchaseCost Decimal @default(0) @db.Decimal(10, 2)

  allowNegativeStock Boolean @default(false)

  isActive Boolean @default(true)

  deletedAt DateTime?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  stockMovements StockMovement[]

  recipeItems RecipeItem[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])

  @@index([deletedAt])

  @@index([name])
}

model Recipe {
  id String @id @default(cuid())

  productId String @unique

  product Product @relation(fields: [productId], references: [id])

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  items RecipeItem[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model RecipeItem {
  id String @id @default(cuid())

  recipeId String

  ingredientId String

  quantity Decimal @db.Decimal(10, 2)

  recipe Recipe @relation(fields: [recipeId], references: [id])

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  createdAt DateTime @default(now())

  @@index([recipeId])

  @@index([ingredientId])
}

model StockMovement {
  id String @id @default(cuid())

  ingredientId String

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  type StockMovementType

  quantity Decimal @db.Decimal(10, 2)

  previousStock Decimal @db.Decimal(10, 2)

  currentStock Decimal @db.Decimal(10, 2)

  unitCost Decimal? @db.Decimal(10, 2)

  totalCost Decimal? @db.Decimal(10, 2)

  reason String?

  referenceId String?

  referenceType String?

  performedById String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([companyId])

  @@index([ingredientId])

  @@index([type])

  @@index([createdAt])
}

model CompanyTheme {
  id String @id @default(cuid())

  companyId String @unique

  company Company @relation(fields: [companyId], references: [id])

  primaryColor String @default("#ef4444")

  secondaryColor String @default("#0f172a")

  backgroundColor String @default("#020617")

  textColor String @default("#ffffff")

  logoUrl String?

  bannerUrl String?

  darkMode Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Cash {
  id String @id @default(cuid())

  openingValue Decimal @db.Decimal(10, 2)

  balance Decimal @db.Decimal(10, 2)

  entries Decimal @default(0) @db.Decimal(10, 2)

  exits Decimal @default(0) @db.Decimal(10, 2)

  isOpen Boolean @default(true)

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model AuditLog {
  id String @id @default(cuid())

  action String

  entity String

  entityId String?

  description String?

  metadata Json?

  ipAddress String?

  userAgent String?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  userId String?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])

  @@index([userId])

  @@index([entity])

  @@index([action])

  @@index([createdAt])
}

// ─── F8: Gateway de Pagamento ───────────────────────────────

model Payment {
  id          String        @id @default(uuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  externalId  String?       // ID gerado pelo Mercado Pago / PagSeguro
  provider    PaymentProvider
  status      PaymentStatus @default(PENDING)
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("BRL")
  checkoutUrl String?       // URL de redirect para o cliente
  webhookData Json?         // payload bruto do webhook
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([orderId])
  @@index([externalId])
  @@index([companyId])
}

enum PaymentProvider {
  MERCADO_PAGO
  PAGSEGURO
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
}

// ─── F7: Sistema de Fidelidade ──────────────────────────────

model LoyaltyAccount {
  id           String             @id @default(uuid())
  customerId   String             @unique
  customer     Customer           @relation(fields: [customerId], references: [id])
  companyId    String
  company      Company            @relation(fields: [companyId], references: [id])
  totalPoints  Int                @default(0)
  totalCashback Decimal           @default(0) @db.Decimal(10, 2)
  transactions PointTransaction[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([customerId, companyId])
  @@index([companyId])
}

model PointTransaction {
  id               String          @id @default(uuid())
  loyaltyAccountId String
  loyaltyAccount   LoyaltyAccount  @relation(fields: [loyaltyAccountId], references: [id])
  orderId          String?
  points           Int             // positivo = ganho, negativo = resgatado
  type             PointType
  description      String?
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())

  @@index([loyaltyAccountId])
}

enum PointType {
  EARNED
  REDEEMED
  EXPIRED
  BONUS
  CASHBACK
}

model Coupon {
  id              String       @id @default(uuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  code            String       @unique
  type            CouponType
  value           Decimal      @db.Decimal(10, 2) // % ou R$ dependendo do type
  minOrderAmount  Decimal?     @db.Decimal(10, 2)
  maxDiscount     Decimal?     @db.Decimal(10, 2)
  usageLimit      Int?
  usageCount      Int          @default(0)
  customerId      String?
  customer        Customer?    @relation(fields: [customerId], references: [id])
  pointsCost      Int?         // pontos necessários para resgatar
  active          Boolean      @default(true)
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([companyId])
  @@index([code])
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

// ─── F6: Chatbot IA ─────────────────────────────────────────

model ChatSession {
  id         String        @id @default(uuid())
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  customerId String?
  sessionKey String        @unique @default(uuid()) // usado no frontend (cookie)
  messages   ChatMessage[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([companyId])
  @@index([sessionKey])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  role      ChatRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

enum ChatRole {
  USER
  ASSISTANT
}

// ─── BI / AI / Alertas ──────────────────────────────────────

enum AlertType {
  LOW_STOCK
  HIGH_CMV
  REVENUE_DROP
  TICKET_DROP
  CANCELLATION_SPIKE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model KpiSnapshot {
  id              String   @id @default(cuid())
  companyId       String
  snapshotAt      DateTime
  revenue         Decimal  @db.Decimal(14, 2)
  cmv             Decimal  @db.Decimal(14, 2)
  grossProfit     Decimal  @db.Decimal(14, 2)
  grossMargin     Decimal  @db.Decimal(7, 4)
  orderCount      Int
  avgTicket       Decimal  @db.Decimal(10, 2)
  cancelledCount  Int
  deliveryCount   Int
  dineInCount     Int
  pickupCount     Int
  pixRevenue      Decimal  @db.Decimal(14, 2)
  cardRevenue     Decimal  @db.Decimal(14, 2)
  cashRevenue     Decimal  @db.Decimal(14, 2)
  createdAt       DateTime @default(now())

  @@unique([companyId, snapshotAt])
  @@index([companyId])
  @@index([snapshotAt])
}

model Alert {
  id          String        @id @default(cuid())
  companyId   String
  type        AlertType
  severity    AlertSeverity
  title       String
  message     String        @db.Text
  metadata    Json?
  read        Boolean       @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([companyId])
  @@index([read])
  @@index([createdAt])
}

model AiConversation {
  id          String      @id @default(cuid())
  companyId   String
  userId      String?
  title       String?
  messages    AiMessage[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([companyId])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           ChatRole
  content        String         @db.Text
  tokensUsed     Int?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

model OperationalCost {
  id          String   @id @default(cuid())
  companyId   String
  category    String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  recurring   Boolean  @default(false)
  period      String?  // MONTHLY | WEEKLY | DAILY
  referenceAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([referenceAt])
}
