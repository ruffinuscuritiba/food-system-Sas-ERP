# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/foodsaas

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ── Cloudinary (imagens) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI — Cadastro Inteligente por Imagem ─────────────────────────────────────
# Ordem de fallback: Gemini -> OpenRouter -> Anthropic
#
# 1. Gemini Flash (RECOMENDADO — gratuito, melhor OCR)
#    Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Modelo padrao: gemini-1.5-flash  (ou gemini-2.0-flash para melhor qualidade)
GEMINI_MODEL=gemini-1.5-flash
#
# 2. OpenRouter (fallback gratuito)
#    Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Modelo padrao: google/gemini-2.0-flash-exp:free  (suporta visao, gratuito)
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
#
# 3. Anthropic Claude (opcional — premium, cobrado por uso)
#    Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=
