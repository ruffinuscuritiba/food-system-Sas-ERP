# ══════════════════════════════════════════════════════════════
# .env.example — docker-compose local
# Copie para .env e preencha os valores antes de rodar:
#   cp .env.example .env
#   docker compose up -d
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=foodsystem
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha-forte

# ── JWT (gere com: openssl rand -hex 64) ─────────────────────
JWT_SECRET=troque-por-string-aleatoria-longa

# ── Super Admin ───────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@sua-empresa.com
SUPER_ADMIN_PASSWORD=troque-senha-forte

# ── URLs ──────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ── Opcionais ─────────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
